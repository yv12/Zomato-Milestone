# ============================================================
# TasteFinder AI — Streamlit Secrets (LOCAL DEV ONLY)
# ============================================================
# Copy this file to:  .streamlit/secrets.toml
# Then fill in your actual API key.
#
# NEVER commit the real secrets.toml — it is in .gitignore.
# For Streamlit Cloud, paste these values in:
#   App Settings → Secrets
# ============================================================

GROQ_API_KEY = "gsk_your_groq_api_key_here"
LLM_MODEL = "llama-3.3-70b-versatile"
EMBEDDING_MODEL_NAME = "sentence-transformers/all-MiniLM-L6-v2"
DATA_PATH = "data/processed/restaurants.sqlite"
MAX_CANDIDATES = "30"
BUDGET_LOW_MAX = "500"
BUDGET_MEDIUM_MAX = "1500"
